# Per-profile env for a Telegram MCP ingest listener on sandbox-ik (pr-hero-xf6).
# Copy to /etc/telegram-mcp/env.d/<profile>.env, chmod 600, fill the values.
# ⚠ NO secret VALUES in git — these are the KEY NAMES / where to get each value.
#
# TELEGRAM_SESSION_STRING must be UNIQUE per endpoint (§Telegram session-per-endpoint):
# generate it ON sandbox-ik by SMS re-auth (owner enters the code once), never copy
# a local/laba session string here — Telegram kills the auth key on reuse.

# which account (drives Supabase schema: ikrasinsky→rick_messages_tasks, lisa→tg_lisa)
TELEGRAM_USER=__PROFILE__

# enables event_handlers ingest (live NewMessage + backfill) — this is a listener, not stdio MCP
LABA_MODE=true

# Telegram API app creds (shared across profiles). Keychain: telegram_api_id / telegram_api_hash
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# per-endpoint session — GENERATE ON sandbox-ik via SMS re-auth (do NOT reuse local/laba)
TELEGRAM_SESSION_STRING=

# Supabase direct Postgres (guardian + writer). Keychain: supabase_rick_db_url
SUPABASE_URL=https://supabase.rick.ai
SUPABASE_DB_URL=
